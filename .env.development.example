# =============================================================================
# 开发环境配置模板（demo-server 风格）
# 使用方式：复制为 `.env.development`（该文件已 gitignore，勿提交密钥）
#   cp .env.development.example .env.development
# 启动：NODE_ENV=development 时自动加载 `.env.development`
# =============================================================================

# -----------------------------------------------------------------------------
# 运行环境
# -----------------------------------------------------------------------------
# NODE_ENV 由 yarn dev / PM2 注入，一般无需在此文件写
# NODE_ENV=development

# HTTP 服务监听端口（与 TiDB 的 4000 端口无关，可同时使用 4000）
PORT=4000

# -----------------------------------------------------------------------------
# 前端 CORS
# -----------------------------------------------------------------------------
# 允许跨域的浏览器 Origin，多个用英文逗号分隔
CLIENT_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# 交易所上游（行情网关）
# -----------------------------------------------------------------------------
# Binance 公共行情 REST（推荐 data-api.binance.vision，专用于 K 线等）
BINANCE_REST_BASE_URL=https://data-api.binance.vision
# Binance 公共行情 WebSocket
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443
# 本服务对外暴露的行情 WS 路径（前端连接 ws://host:PORT + 此路径）
MARKET_WS_PATH=/ws/market
# /api/v1/market/* 每 IP 每分钟最大请求数
MARKET_RATE_LIMIT_PER_MIN=120

# -----------------------------------------------------------------------------
# 认证 JWT
# -----------------------------------------------------------------------------
# 签发/校验 Bearer Token 的密钥；pre/prod 必填
JWT_SECRET=dev-change-me
# Token 有效期，如 7d、12h
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# 邮件（Resend）— 注册 / 找回密码验证码
# -----------------------------------------------------------------------------
# true 时通过 Resend 发信；false 时开发环境仅在控制台打印验证码
MAIL_ENABLED=true
RESEND_API_KEY=re_xxxxxxxx
# 使用已在 Resend 验证的域名，例如 aipassly.com
MAIL_FROM=Polaris <noreply@aipassly.com>
# 无需登录即可访问的路径前缀（逗号分隔）
AUTH_SKIP_PATHS=/health,/api/v1/market,/api/v1/dashboard,/api/v1/events,/ws/market,/ws/events

# --- 事件情报（可选）---
EVENTS_WS_PATH=/ws/events
# 默认 false：事件流与 GET /events 一样公开只读；生产若需鉴权改为 true
EVENTS_WS_REQUIRE_AUTH=false
LIQUIDATION_WORKER_ENABLED=true
# INGEST_INTERVAL_MS=900000
# MVP Lite：ingest 仅 RSS×2；品种列表见 t_trading_symbol（yarn db:init）

# -----------------------------------------------------------------------------
# 数据库（MySQL 兼容：本地 MySQL / TiDB Cloud）
# -----------------------------------------------------------------------------
# 是否启动时连接数据库；false 时仅行情接口可用
DB_ENABLED=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=trading-alpha
# TiDB Cloud / 托管库需开启 TLS
# DB_SSL=true
# pre/prod 可从 KMS 拉取密码时的密钥名（可选，尚未接入）
# DB_ASM=trading-api_pre
