# =============================================================================
# 预发环境（demo-server 风格）
# 启动：NODE_ENV=pre → 自动加载本文件；部署机填写真实值，密码勿提交仓库
# =============================================================================

# --- 服务 ---
PORT=4000

# --- 前端 CORS（多个 Origin 用英文逗号分隔）---
CLIENT_ORIGINS=https://staging.your-frontend-domain.com

# --- 交易所上游 ---
BINANCE_REST_BASE_URL=https://data-api.binance.vision
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443
MARKET_WS_PATH=/ws/market
MARKET_RATE_LIMIT_PER_MIN=120

# --- JWT（pre 必填，见 config/index.ts 启动校验）---
JWT_SECRET=
JWT_EXPIRES_IN=7d
AUTH_SKIP_PATHS=/health,/api/v1/market,/api/v1/dashboard,/api/v1/events,/ws/market,/ws/events
EVENTS_WS_PATH=/ws/events
LIQUIDATION_WORKER_ENABLED=true

# --- 数据库 ---
DB_ENABLED=true
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=trading-alpha
# DB_SSL=true          # 托管库 / TiDB Cloud 开启
# DB_ASM=trading-api_pre   # 从 KMS 拉密码时的键名（可选）
