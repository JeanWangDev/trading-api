{
  "name": "trading-api",
  "version": "0.1.0",
  "description": "Trading platform backend",
  "private": true,
  "main": "dist/server.js",
  "license": "MIT",
  "packageManager": "yarn@4.11.0",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "dev:watch": "nodemon",
    "pre": "NODE_ENV=pre tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "NODE_ENV=production node dist/server.js",
    "deploy:dev": "sh scripts/deploy.sh development",
    "deploy:pre": "sh scripts/deploy.sh pre",
    "deploy:prod": "sh scripts/deploy.sh production",
    "lint": "eslint src --ext .ts --fix",
    "db:init": "tsx scripts/db-init.ts",
    "seed:admin-users": "tsx scripts/seed-admin-users.ts"
  },
  "dependencies": {
    "@koa/router": "^15.5.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "koa": "^3.2.1",
    "koa-bodyparser": "^4.4.1",
    "koa-compress": "^5.2.1",
    "module-alias": "^2.2.3",
    "mysql2": "^3.14.1",
    "resend": "^6.12.4",
    "rss-parser": "^3.13.0",
    "sequelize": "^6.37.7",
    "undici": "^8.3.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa": "^3.0.3",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-compress": "^4.0.7",
    "@types/koa__router": "^12.0.5",
    "@types/module-alias": "^2.0.4",
    "@types/node": "^25.9.1",
    "@types/sequelize": "^4.28.20",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "_moduleAliases": {
    "@": "dist"
  }
}
